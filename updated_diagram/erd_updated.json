{
  "entities": {
    "University": {
      "id": "uuid",
      "name": "string",
      "admin_id": "uuid",
      "location": "string"
    },
    "UniversityAdmin": {
      "id": "uuid",
      "name": "string",
      "email": "string",
      "password": "string",
      "university_id": "uuid"
    },
    "Teacher": {
      "id": "uuid",
      "name": "string",
      "email": "string",
      "password": "string",
      "university_id": "uuid",
      "is_verified": "boolean"
    },
    "Student": {
      "id": "uuid",
      "name": "string",
      "email": "string",
      "password": "string",
      "university_id": "uuid",
      "admin_id": "uuid",
      "is_verified": "boolean"
    },
    "Employer": {
      "id": "uuid",
      "name": "string",
      "email": "string",
      "company": "string",
      "password": "string"
    },
    "Vacancy": {
      "id": "uuid",
      "type": "enum['internship','job']",
      "description": "string",
      "company": "string",
      "location": "string",
      "mode": "enum['online','offline','hybrid']",
      "salary": "number",
      "is_expired": "boolean",
      "start_date": "date",
      "end_date": "date",
      "employer_id": "uuid"
    },
    "Project": {
      "id": "uuid",
      "title": "string",
      "description": "string",
      "student_id": "uuid",
      "teacher_id": "uuid",
      "university_id": "uuid",
      "is_approved": "boolean",
      "is_active": "boolean"
    },
    "Skill": {
      "id": "uuid",
      "name": "string",
      "type": "string"
    },
    "Message": {
      "id": "uuid",
      "sender_id": "uuid",
      "receiver_id": "uuid",
      "context_type": "enum['student','teacher','project','vacancy','university']",
      "content": "text",
      "attachment_links": "string[]",
      "created_at": "timestamp"
    },
    "Users": {
      "user_id": "uuid",
      "role": "enum['student','teacher','university_admin','employer','super_admin']",
      "refresh_token": "text | null",
      "created_at": "timestamp",
      "updated_at": "timestamp",
      "is_active": "boolean"
    }
  },
  "relationships": {
    "University": {
      "has_many": [
        "UniversityAdmin",
        "Teacher",
        "Student",
        "Project"
      ]
    },
    "UniversityAdmin": {
      "belongs_to": [
        "University",
        "Users"
      ]
    },
    "Teacher": {
      "belongs_to": [
        "University",
        "Users"
      ],
      "has_many": [
        "Project"
      ]
    },
    "Student": {
      "belongs_to": [
        "University",
        "Users"
      ],
      "has_many": [
        "Project"
      ]
    },
    "Employer": {
      "has_many": [
        "Vacancy"
      ],
      "belongs_to": "Users"
    },
    "Vacancy": {
      "belongs_to": "Employer",
      "has_many": [
        "Skill"
      ]
    },
    "Project": {
      "belongs_to": [
        "Student",
        "Teacher",
        "University"
      ],
      "has_many": [
        "Skill",
        "Message"
      ]
    },
    "Skill": {
      "many_to_many": [
        "Project",
        "Vacancy",
        "Student"
      ]
    },
    "Message": {
      "belongs_to": [
        "Student",
        "Teacher",
        "Employer",
        "University"
      ]
    },
    "Users": {
      "has_many": [
        "Student",
        "Teacher",
        "UniversityAdmin",
        "Employer"
      ]
    }
  },
  "modules": {
    "UniversityModule": [
      "create_university",
      "activate_university",
      "deactivate_university",
      "update_university"
    ],
    "UniAdminModule": [],
    "TeacherModule": [
      "register_teacher",
      "verify_teacher",
      "update_teacher"
    ],
    "StudentModule": [
      "register_student",
      "login_student",
      "update_student"
    ],
    "ProjectModule": [
      "create_project",
      "update_project",
      "request_verification",
      "verify_project",
      "unverify_project",
      "deactivate_project"
    ],
    "SkillModule": [
      "create_skill",
      "assign_skill_to_project",
      "assign_skill_to_student",
      "assign_skill_to_vacancy"
    ],
    "VacancyModule": [
      "create_vacancy",
      "activate_vacancy",
      "deactivate_vacancy",
      "update_vacancy"
    ],
    "MessagingModule": [
      "send_message",
      "get_messages"
    ],
    "EmployerModule": [
      "register_employer",
      "login_employer",
      "update_employer"
    ],
    "AuthModule": [
      "add_user",
      "verify_refresh_token",
      "refresh_token_rotation",
      "activate_user",
      "deactivate_user"
    ]
  },
