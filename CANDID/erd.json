{
  "entities": {
    "University": {
      "id": "uuid",
      "name": "string",
      "admin_id": "uuid",
      "location": "string"
    },
    "UniversityAdmin": {
      "id": "uuid",
      "name": "string",
      "email": "string",
      "password": "string",
      "university_id": "uuid",
      "is_active": "boolean"
    },
    "Teacher": {
      "id": "uuid",
      "name": "string",
      "email": "string",
      "password": "string",
      "university_id": "uuid",
      "is_verified": "boolean",
      "is_active": "boolean"
    },
    "Student": {
      "id": "uuid",
      "name": "string",
      "email": "string",
      "password": "string",
      "university_id": "uuid",
      "admin_id": "uuid",
      "is_verified": "boolean",
      "is_active": "boolean"
    },
    "Employer": {
      "id": "uuid",
      "name": "string",
      "email": "string",
      "company": "string",
      "password": "string",
      "is_active": "boolean"
    },
    "Vacancy": {
      "id": "uuid",
      "type": "enum['internship','job']",
      "description": "string",
      "company": "string",
      "location": "string",
      "mode": "enum['online','offline','hybrid']",
      "salary": "number",
      "is_expired": "boolean",
      "start_date": "date",
      "end_date": "date",
      "employer_id": "uuid"
    },
    "Project": {
      "id": "uuid",
      "title": "string",
      "description": "string",
      "student_id": "uuid",
      "teacher_id": "uuid",
      "university_id": "uuid",
      "is_university_project": "boolean",
      "verification_status": "enum['none','pending','verified','rejected']",
      "verification_badge": "enum['poor','medium','satisfactory'] | null",
      "verified_by_type": "enum['teacher','university_admin'] | null",
      "verified_by_id": "uuid | null",
      "verified_at": "timestamp | null",
      "is_active": "boolean"
    },
    "VerificationRequest": {
      "id": "uuid",
      "project_id": "uuid",
      "student_id": "uuid",
      "university_id": "uuid",
      "reviewer_type": "enum['teacher','university_admin']",
      "reviewer_id": "uuid",
      "status": "enum['pending','approved','rejected']",
      "badge": "enum['poor','medium','satisfactory'] | null",
      "review_note": "text | null",
      "created_at": "timestamp",
      "updated_at": "timestamp"
    },
    "Skill": {
      "id": "uuid",
      "name": "string",
      "type": "string"
    },
    "Message": {
      "id": "uuid",
      "sender_type": "enum['student','teacher','university_admin','employer']",
      "sender_id": "uuid",
      "receiver_type": "enum['student','teacher','university_admin','employer']",
      "receiver_id": "uuid",
      "context_type": "enum['student','teacher','project','vacancy','university']",
      "context_id": "uuid | null",
      "content": "text",
      "attachment_links": "string[]",
      "created_at": "timestamp"
    }
  },
  "relationships": {
    "University": {
      "has_many": [
        "UniversityAdmin",
        "Teacher",
        "Student",
        "Project",
        "VerificationRequest"
      ]
    },
    "UniversityAdmin": {
      "belongs_to": "University"
    },
    "Teacher": {
      "belongs_to": "University",
      "has_many": [
        "Project",
        "VerificationRequest"
      ]
    },
    "Student": {
      "belongs_to": "University",
      "has_many": [
        "Project",
        "VerificationRequest"
      ]
    },
    "Employer": {
      "has_many": [
        "Vacancy",
        "Message"
      ]
    },
    "Vacancy": {
      "belongs_to": "Employer",
      "has_many": [
        "Skill",
        "Message"
      ]
    },
    "Project": {
      "belongs_to": [
        "Student",
        "Teacher",
        "University"
      ],
      "has_many": [
        "Skill",
        "Message",
        "VerificationRequest"
      ]
    },
    "VerificationRequest": {
      "belongs_to": [
        "Project",
        "Student",
        "University"
      ],
      "reviewer_polymorphic": [
        "Teacher",
        "UniversityAdmin"
      ]
    },
    "Skill": {
      "many_to_many": [
        "Project",
        "Vacancy",
        "Student"
      ]
    },
    "Message": {
      "sender_receiver_polymorphic": true,
      "context_optional": true
    }
  },
  "modules": {
    "UniversityModule": [
      "create_university",
      "activate_university",
      "deactivate_university",
      "update_university"
    ],
    "UniAdminModule": [],
    "TeacherModule": [
