      "unverify_project",
      "deactivate_project"
    ],
    "VerificationRequestModule": [
      "create_verification_request",
      "list_pending_requests",
      "approve_request_with_badge",
      "reject_request_with_note"
    ],
    "SkillModule": [
      "create_skill",
      "assign_skill_to_project",
      "assign_skill_to_student",
      "assign_skill_to_vacancy"
    ],
    "VacancyModule": [
      "create_vacancy",
      "activate_vacancy",
      "deactivate_vacancy",
      "update_vacancy"
    ],
    "MessagingModule": [
      "send_message",
      "get_messages"
    ],
    "EmployerModule": [
      "register_employer",
      "login_employer",
      "activate_employer",
      "update_employer"
    ]
  },
